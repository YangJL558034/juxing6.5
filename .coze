[project]
requires = [ "nodejs-24" ]
template = "nextjs"
version = "0.0.21"
appliedPatches = [ ]

[dev]
build = [ "pnpm", "install" ]
run = [ "pnpm", "tsx", "watch", "src/server.ts" ]
validate = [ "bash", "./scripts/validate.sh" ]
deps = [ "git" ]

[deploy]
build = [ "bash", "./scripts/build.sh" ]
run = [ "bash", "./scripts/start.sh" ]
deps = [ "git" ]
